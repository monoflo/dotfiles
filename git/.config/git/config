[include]
    path = private  # private / sensitive config settings


[alias]
    a    = add
    b    = branch
    bd   = branch --delete
    c    = commit
    cb   = checkout --branch
    co   = checkout
    cl   = config --list
    d    = diff
    dc   = diff --cached
    dv   = difftool --no-prompt
    last = log -1 HEAD --stat
    ps   = push origin HEAD
    r    = remote --verbose
    s    = status
    u    = reset HEAD~1

[core]
    editor = vim

[fetch]
    prune = true

[help]
    autocorrect = 20

[init]
    defaultBranch = main  # comply with GitHub.com

[merge]
    tool = vimdiff

[pull]
    rebase = true

[status]
    short = true
