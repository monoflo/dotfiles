src()  { [[ ! -r "$1" ]] && echo "src: \`$1\` not readable" 2>&1 || source "$1"; }
path() { [[ ! -d "$1" ]] && echo "path: \`$1\` not a directory" 2>&1 || export PATH="$PATH:$1"; }

export CARGO_HOME="$HOME/.cargo"
export PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/local/lib64/pkgconfig
export XDG_CONFIG_HOME="$HOME/.config"

alias c="cargo"
alias g="git"
alias v="nvim"
alias vim="nvim"

src "$HOME/.profile-secret"
src "$CARGO_HOME/env"

path "$HOME/.local/bin"
path "$CARGO_HOME/bin"
