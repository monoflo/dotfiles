src()  { [ -r "$1" ] && source "$1"; }
path() { [ -d "$1" ] && test "${PATH#*$1}" == "$PATH" && export PATH="$PATH:$1"; }

for rc in "$HOME"/.profile.d/*; do src "$rc"; done; unset rc

src "$CARGO_HOME/env"

path "$HOME/.local/bin"
path "$CARGO_HOME/bin"

[ -n "$BASH_VERSION" ] && src "$HOME/.bashrc"
